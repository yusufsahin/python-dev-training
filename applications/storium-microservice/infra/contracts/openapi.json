        "required": [
          "name",
          "slug",
          "url"
        ],
        "title": "BreadcrumbItemDTO"
      },
      "CartDTO": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/CartItemDTO"
            },
            "type": "array",
            "title": "Items"
          },
          "total_price": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Total Price"
          },
          "item_count": {
            "type": "integer",
            "title": "Item Count"
          },
          "unique_item_count": {
            "type": "integer",
            "title": "Unique Item Count"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total_price",
          "item_count",
          "unique_item_count"
        ],
        "title": "CartDTO"
      },
      "CartItemAdd": {
        "properties": {
          "product_id": {
            "type": "integer",
            "title": "Product Id"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Quantity",
            "default": 1
          }
        },
        "type": "object",
        "required": [
          "product_id"
        ],
        "title": "CartItemAdd"
      },
      "CartItemDTO": {
        "properties": {
          "product_id": {
            "type": "integer",
            "title": "Product Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "price": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Price"
          },
          "quantity": {
            "type": "integer",
            "title": "Quantity"
          },
          "image_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Image Url"
          },
          "line_total": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Line Total",
            "readOnly": true
          }
        },
        "type": "object",
        "required": [
          "product_id",
          "name",
          "price",
          "quantity",
          "line_total"
        ],
        "title": "CartItemDTO"
      },
      "CategoryNavNode": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "slug": {
            "type": "string",
            "title": "Slug"
